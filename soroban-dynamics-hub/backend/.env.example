# ──────────────────────────────────────────────────────────────
# Soroban State Dynamics Hub — Backend Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Stellar RPC / Soroban RPC endpoint (testnet)
# Default: https://soroban-testnet.stellar.org
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Horizon URL for the Stellar testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# The deployed contract ID (hex string, no 0x prefix)
CONTRACT_ID=

# Network passphrase for the target network
# Testnet: "Test SDF Network ; September 2015"
# Mainnet: "Public Global Stellar Network ; September 2015"
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Server port
PORT=3001
